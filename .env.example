# =============================================================================
# VIGIL APEX — .env.example
# =============================================================================
# This file is the SINGLE source of truth for every environment variable the
# production stack reads. Copy to `.env` (gitignored) and fill in values.
#
# RULES (enforced by gitleaks pre-commit):
#   - NEVER commit a real .env file.
#   - NEVER inline a real secret here, even temporarily.
#   - Every value below is either a placeholder (PLACEHOLDER_*) or a
#     non-sensitive default (e.g. service hostnames, ports).
#   - Real secrets are loaded from Vault at container start; the variables
#     below carry only Vault paths or non-secret config.
#
# Per SRD §17.6 & §17.12 — Vault is the only secret store. No exceptions.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info                            # trace | debug | info | warn | error | fatal
TZ=Africa/Douala                          # SRD §3.9 — host clock binding
VIGIL_PHASE=0                             # 0..6 — phase pointer; CI gate enforces

# -----------------------------------------------------------------------------
# Vault — every other secret comes from here
# -----------------------------------------------------------------------------
VAULT_ADDR=http://vigil-vault:8200
VAULT_NAMESPACE=                          # empty in OSS; set if Enterprise
VAULT_TOKEN_FILE=/run/secrets/vault_token_worker  # AppRole-issued, 1h TTL
VAULT_KV_MOUNT=secret
VAULT_TRANSIT_MOUNT=transit
VAULT_PKI_MOUNT=pki/internal

# -----------------------------------------------------------------------------
# PostgreSQL — authoritative store (SRD §07)
# -----------------------------------------------------------------------------
POSTGRES_HOST=vigil-postgres
POSTGRES_PORT=5432
POSTGRES_DB=vigil
POSTGRES_USER=vigil
POSTGRES_PASSWORD_FILE=/run/secrets/pg_password
POSTGRES_SSLMODE=verify-full
POSTGRES_SSLROOTCERT=/run/vigil/certs/postgres-ca.pem
# Pool tuning
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20
POSTGRES_STATEMENT_TIMEOUT_MS=30000
POSTGRES_LOCK_TIMEOUT_MS=5000
POSTGRES_IDLE_IN_TX_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# Neo4j — derived graph (SRD §08)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://vigil-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD_FILE=/run/secrets/neo4j_password
NEO4J_DATABASE=vigil
NEO4J_MAX_CONN_POOL_SIZE=50
NEO4J_CONN_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Redis — streams + cache (SRD §08.5)
# -----------------------------------------------------------------------------
REDIS_HOST=vigil-redis
REDIS_PORT=6379
REDIS_PASSWORD_FILE=/run/secrets/redis_password
REDIS_DB=0
REDIS_TLS=false                            # internal vigil-internal network
# Streams
REDIS_STREAM_MAX_LEN=1000000
REDIS_STREAM_BLOCK_MS=5000
REDIS_CONSUMER_IDLE_RECLAIM_MS=300000     # 5 min — reclaim from dead consumers

# -----------------------------------------------------------------------------
# IPFS (Kubo) — content-addressed evidence (SRD §14)
# -----------------------------------------------------------------------------
IPFS_API_URL=http://vigil-ipfs:5001
IPFS_GATEWAY_URL=http://vigil-ipfs:8080
IPFS_PIN_TIMEOUT_MS=60000
IPFS_PROFILE=server

# -----------------------------------------------------------------------------
# Audit chain — Postgres hash chain + Polygon anchor (W-11 fix; SRD §22)
# -----------------------------------------------------------------------------
AUDIT_HASH_ALGO=sha256
AUDIT_BATCH_INTERVAL_MS=60000             # batch hash-chain commits every 60 s
AUDIT_ANCHOR_INTERVAL_MS=3600000          # anchor to Polygon every hour
POLYGON_RPC_URL=https://polygon-rpc.com   # default; Alchemy preferred in prod
POLYGON_RPC_FALLBACK_URLS=https://rpc.ankr.com/polygon,https://polygon.llamarpc.com
POLYGON_CHAIN_ID=137
POLYGON_ANCHOR_CONTRACT=PLACEHOLDER_DEPLOYED_AT_M1
POLYGON_GOVERNANCE_CONTRACT=PLACEHOLDER_DEPLOYED_AT_M3
POLYGON_GAS_PRICE_GWEI_MAX=200            # circuit-break above this
POLYGON_SIGNER_SOCKET=/run/vigil/polygon-signer.sock

# -----------------------------------------------------------------------------
# LLM tier router (SRD §18, MVP §06)
# -----------------------------------------------------------------------------
# Tier 0 — Anthropic direct
ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_MS=60000

# Tier 1 — AWS Bedrock failover
AWS_BEDROCK_ENABLED=true
AWS_BEDROCK_REGION=eu-west-1
AWS_ACCESS_KEY_ID_FILE=/run/secrets/aws_access_key_id
AWS_SECRET_ACCESS_KEY_FILE=/run/secrets/aws_secret_access_key
AWS_BEDROCK_MODEL_OPUS=anthropic.claude-opus-4-7
AWS_BEDROCK_MODEL_SONNET=anthropic.claude-sonnet-4-6
AWS_BEDROCK_MODEL_HAIKU=anthropic.claude-haiku-4-5-20251001

# Tier 2 — local sovereign (DEGRADED MODE; held-for-review only)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL_PRIMARY=qwen2.5:72b
LOCAL_LLM_MODEL_FALLBACK=deepseek-r1:70b

# Circuit breaker
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_FAILURE_WINDOW_MS=60000
LLM_CIRCUIT_TIMEOUT_LATENCY_MS=30000
LLM_CIRCUIT_PROBE_INTERVAL_MS=60000

# Cost ceilings (USD)
LLM_DAILY_SOFT_CEILING_USD=30
LLM_DAILY_HARD_CEILING_USD=100
LLM_MONTHLY_BUDGET_USD=2503

# -----------------------------------------------------------------------------
# Authentication — Keycloak FIDO2 (SRD §17.9)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://vigil-keycloak:8080
KEYCLOAK_REALM=vigil-apex
KEYCLOAK_CLIENT_ID=vigil-dashboard
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD_FILE=/run/secrets/keycloak_admin
KEYCLOAK_ISSUER=https://kc.vigilapex.cm/realms/vigil-apex
KEYCLOAK_AUDIENCE=vigil-dashboard

# -----------------------------------------------------------------------------
# Adapter runner — proxy + scraping (SRD §13)
# -----------------------------------------------------------------------------
ADAPTER_USER_AGENT=VIGIL-APEX/1.0 (anti-corruption pilot, +https://vigilapex.cm/contact)
ADAPTER_HONOR_ROBOTS=true
ADAPTER_DEFAULT_RATE_INTERVAL_MS=2000
ADAPTER_DAILY_REQUEST_CAP_PER_SOURCE=10000

# Proxy providers (W-13 layered egress)
PROXY_HETZNER_DC_ENABLED=true
PROXY_BRIGHT_DATA_ENABLED=true
PROXY_BRIGHT_DATA_USERNAME_FILE=/run/secrets/bright_data_user
PROXY_BRIGHT_DATA_PASSWORD_FILE=/run/secrets/bright_data_pass
PROXY_BRIGHT_DATA_ZONE=residential
PROXY_TOR_ENABLED=true
PROXY_TOR_SOCKS_HOST=vigil-tor
PROXY_TOR_SOCKS_PORT=9050
PROXY_TOR_CONTROL_PORT=9051

# Captcha (CapMonster / 2captcha)
CAPTCHA_PROVIDER=capmonster
CAPTCHA_API_KEY_FILE=/run/secrets/captcha_api_key
CAPTCHA_MONTHLY_BUDGET_USD=500

# -----------------------------------------------------------------------------
# CONAC SFTP delivery (SRD §25, W-25 format-adapter layer)
# -----------------------------------------------------------------------------
CONAC_SFTP_HOST=PLACEHOLDER_PROVISIONED_AT_M3
CONAC_SFTP_PORT=22
CONAC_SFTP_USER=vigilapex
CONAC_SFTP_PRIVATE_KEY_FILE=/run/secrets/conac_sftp_key
CONAC_SFTP_HOSTKEY_FINGERPRINT=PLACEHOLDER
CONAC_INBOX=/inbox/vigil-apex
CONAC_ACK_DIR=/ack/vigil-apex
CONAC_FORMAT_ADAPTER=v1                   # plug-in version per W-25
# Plan-B target if CONAC declines
COURDESCOMPTES_DELIVERY_ENABLED=false

# -----------------------------------------------------------------------------
# MINFI scoring API (SRD §26)
# -----------------------------------------------------------------------------
MINFI_API_PORT=4001
MINFI_API_RATE_LIMIT_PER_MINUTE=600
MINFI_API_IDEMPOTENCY_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Tip portal (SRD §28; W-09 .onion)
# -----------------------------------------------------------------------------
TIP_RATE_LIMIT_WINDOW_MIN=60
TIP_RATE_LIMIT_MAX_PER_FP=5
TIP_OPERATOR_TEAM_PUBKEY=PLACEHOLDER_LIBSODIUM_BASE64
TIP_ONION_HOSTNAME=PLACEHOLDER_HIDDEN_SERVICE.onion

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://vigil-otel-collector:4318
OTEL_SERVICE_NAME=vigil-apex
PROMETHEUS_PORT=9100
GRAFANA_PORT=3001

# -----------------------------------------------------------------------------
# Anti-hallucination (SRD §20; W-14)
# -----------------------------------------------------------------------------
HALLUCINATION_CORPUS_PATH=/app/packages/llm/__tests__/synthetic-hallucinations.jsonl
HALLUCINATION_REJECTION_THRESHOLD=0.95
QUOTE_MATCH_REJECTION_TARGET=0.08
NUMERICAL_DISAGREEMENT_TARGET=0.05
SCHEMA_VIOLATION_TARGET=0.02
ECE_WARNING_THRESHOLD=0.05
ECE_ALARM_THRESHOLD=0.10

# -----------------------------------------------------------------------------
# Domain & TLS (W-09 .onion + clearnet)
# -----------------------------------------------------------------------------
PUBLIC_DOMAIN=vigilapex.cm
PUBLIC_DOMAIN_FALLBACK=vigilapex.org
ACME_EMAIL=ops@vigilapex.cm
ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# -----------------------------------------------------------------------------
# Backup architect — W-17
# -----------------------------------------------------------------------------
BACKUP_ARCHITECT_EMAIL=PLACEHOLDER
BACKUP_ARCHITECT_RETAINER_EUR=400
BACKUP_ARCHITECT_KEY_FINGERPRINT=PLACEHOLDER

# -----------------------------------------------------------------------------
# Phase gates — see CLAUDE.md
# -----------------------------------------------------------------------------
PHASE_0_GATE_FILE=docs/decisions/DRY-RUN-DECISION.md
PHASE_1_PRECONDITION_YUBIKEYS_DELIVERED=false
PHASE_1_PRECONDITION_COUNCIL_NAMED_COUNT=0
PHASE_5_PRECONDITION_COUNCIL_ENROLLED_COUNT=0
PHASE_6_PRECONDITION_CONAC_LETTER_COUNTERSIGNED=false
PHASE_9_PRECONDITION_CALIBRATION_SEED_COUNT=0

# -----------------------------------------------------------------------------
# Connection-string aliases (read directly by code, alongside HOST/PORT pairs
# above). Keep both shapes consistent.
# -----------------------------------------------------------------------------
POSTGRES_URL=postgres://vigil:vigil@vigil-postgres:5432/vigil
POSTGRES_POOL_IDLE_TIMEOUT_MS=10000
REDIS_URL=redis://vigil-redis:6379
REDIS_PASSWORD=                            # populated from REDIS_PASSWORD_FILE; raw value here only in dev

# -----------------------------------------------------------------------------
# Keycloak (auth) — JWKS endpoint reachable by the dashboard middleware
# -----------------------------------------------------------------------------
KEYCLOAK_JWKS_URL=                         # default: ${KEYCLOAK_ISSUER}/protocol/openid-connect/certs

# -----------------------------------------------------------------------------
# Sentry / error reporting
# -----------------------------------------------------------------------------
SENTRY_DSN=                                # leave empty to disable; populated per environment
DEPLOY_ENV=development                     # production | staging | development — tags Sentry events
NEXT_PUBLIC_DEPLOY_ENV=development         # mirrored to client bundle for Sentry tagging
NEXT_PUBLIC_SENTRY_DSN=                    # public-side Sentry DSN (different project from server-side)
NEXT_PUBLIC_RELEASE=                       # git-sha or semver; tags releases in Sentry

# -----------------------------------------------------------------------------
# Public dashboard config (served to the browser bundle)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POLYGON_EXPLORER=https://polygonscan.com/tx/
NEXT_PUBLIC_TURNSTILE_SITEKEY=             # Cloudflare Turnstile public site key for /tip
NEXT_PUBLIC_ANTIC_DECLARATION_URL=         # link to ANTIC declaration record once filed (W-23)

# -----------------------------------------------------------------------------
# Tip portal — server-side
# -----------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=                      # Cloudflare Turnstile secret; required if /tip enabled

# -----------------------------------------------------------------------------
# Adapter runner — sources registry path + first-contact archive
# -----------------------------------------------------------------------------
SOURCES_REGISTRY_PATH=infra/sources.json
ADAPTER_FIRST_CONTACT_ARCHIVE=/srv/vigil/first-contact-archive
ADAPTER_REPAIR_THRESHOLD=24                # hours of consecutive failures before repair worker kicks in
PROXY_TOR_ENABLED=0                        # 1 = require PROXY_TOR_SOCKS_HOST set explicitly

# -----------------------------------------------------------------------------
# OCR pool size for worker-document
# -----------------------------------------------------------------------------
OCR_POOL_SIZE=2

# -----------------------------------------------------------------------------
# Audit verifier interval
# -----------------------------------------------------------------------------
AUDIT_VERIFY_INTERVAL_MS=3600000           # 1 h — CT-01/02/03 cross-witness sweep

# -----------------------------------------------------------------------------
# CONAC delivery — signer manifest fields (W-25)
# -----------------------------------------------------------------------------
SIGNER_NAME=                               # full name of the signer; required to ship CONAC manifests
GPG_FINGERPRINT=                           # 40-hex-char OpenPGP fingerprint; PLACEHOLDER refused at boot

# -----------------------------------------------------------------------------
# MINFI pre-disbursement scoring API (SRD §26)
# -----------------------------------------------------------------------------
MINFI_API_MTLS=0                           # 1 = require client cert; reads MINFI_API_TLS_* below
MINFI_API_TLS_CERT=/run/secrets/minfi_tls_cert
MINFI_API_TLS_KEY=/run/secrets/minfi_tls_key
MINFI_API_TLS_CA=/run/secrets/minfi_tls_ca

# -----------------------------------------------------------------------------
# MOU-gated adapters (no-ops until *_ENABLED=1)
# -----------------------------------------------------------------------------
ANIF_ENABLED=0
ANIF_BASE_URL=https://anif.minfi.cm/api/v2
ANIF_API_KEY=
ANIF_API_KEY_FILE=/run/secrets/anif_api_key
ANIF_PEP_SURFACE_ALLOWED=0                 # 1 = pep_match events surface to operator UI; 0 = stripped at adapter
BEAC_ENABLED=0
BEAC_BASE_URL=https://api.beac.int/payments/v1
BEAC_TOKEN_URL=https://auth.beac.int/oauth2/token
BEAC_CLIENT_ID=
BEAC_CLIENT_SECRET=
MINFI_BIS_ENABLED=0
MINFI_BIS_BASE_URL=https://bis.minfi.cm/api/v3
MINFI_BIS_LOOKBACK_HOURS=24

# -----------------------------------------------------------------------------
# Third-party data providers (commercial keys; populate from Vault in prod)
# -----------------------------------------------------------------------------
ALEPH_API_KEY=                             # OCCRP Aleph API key (occrp-aleph adapter)
OPENCORPORATES_API_KEY=                    # OpenCorporates v0.4 API key

# -----------------------------------------------------------------------------
# Phase-3 federation (scaffold-only; only set on regional cutover)
# -----------------------------------------------------------------------------
VIGIL_REGION_CODE=                         # e.g. CE, LT, NW, OU, SW, SU, ES, EN, NO, AD
VIGIL_SIGNING_KEY_ID=                      # ed25519 key id; must prefix VIGIL_REGION_CODE
FEDERATION_CORE_ENDPOINT=                  # gRPC endpoint of the Yaoundé core
FEDERATION_LISTEN=0.0.0.0:50051            # bind address for the regional federation server
FEDERATION_KEY_DIR=/srv/vigil/federation/keys
FEDERATION_SIGNING_KEY=                    # path to ed25519 private key file (regional agent)
FEDERATION_BATCH_SIZE=64
FEDERATION_BATCH_MS=2000
FEDERATION_TLS_CERT=                       # path; leave empty only if VIGIL_FEDERATION_INSECURE_OK=true
FEDERATION_TLS_KEY=
FEDERATION_TLS_ROOT=
FEDERATION_CLIENT_CA=
FEDERATION_THROTTLE_HINT_MS=               # optional override
VIGIL_FEDERATION_INSECURE_OK=              # "true" only for in-process tests; never set in production

# -----------------------------------------------------------------------------
# Hyperledger Fabric audit witness (P2 scaffold)
# -----------------------------------------------------------------------------
FABRIC_PEER_ENDPOINT=                      # leave empty pre-Phase-2 — audit-verifier skips CT-03 then
FABRIC_PEER_HOST_ALIAS=
FABRIC_TLS_ROOT=
FABRIC_CHANNEL=audit-channel
FABRIC_CHAINCODE=audit-witness
FABRIC_MSP_ID=Org1MSP
FABRIC_CLIENT_CERT=
FABRIC_CLIENT_KEY=

# -----------------------------------------------------------------------------
# Dossier signing safety opt-in (do NOT set in production)
# -----------------------------------------------------------------------------
VIGIL_DEV_ALLOW_UNSIGNED_DOSSIER=          # "true" lets worker-dossier write unsigned PDFs in dev

# -----------------------------------------------------------------------------
# LLM — monthly circuit-breaker fraction
# -----------------------------------------------------------------------------
LLM_MONTHLY_CIRCUIT_FRACTION=0.85          # cut Anthropic when month-to-date spend >= fraction × budget

# -----------------------------------------------------------------------------
# Test harness
# -----------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL=http://localhost:3000
CI=                                        # set to any non-empty value in CI runners
