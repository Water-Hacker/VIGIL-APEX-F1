{
  "name": "worker-adapter-repair",
  "version": "0.1.0",
  "private": true,
  "description": "W-19 self-healing — LLM re-derives broken adapter selectors and shadow-tests against the live source before promotion.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/db-postgres": "workspace:*",
    "@vigil/llm": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/queue": "workspace:*",
    "@vigil/security": "workspace:*",
    "@vigil/shared": "workspace:*",
    "drizzle-orm": "^0.34.0",
    "node-cron": "^3.0.3",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/node-cron": "^3.0.11",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
