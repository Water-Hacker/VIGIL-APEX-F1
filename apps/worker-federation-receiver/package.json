{
  "name": "worker-federation-receiver",
  "version": "0.1.0",
  "private": true,
  "description": "Phase-3 core-side federation receiver. Hosts the federation-stream gRPC server, verifies signed envelopes, and forwards into the existing pattern-detect pipeline.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/federation-stream": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/queue": "workspace:*",
    "@vigil/shared": "workspace:*",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
