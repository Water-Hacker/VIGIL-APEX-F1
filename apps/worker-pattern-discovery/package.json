{
  "name": "worker-pattern-discovery",
  "version": "0.1.0",
  "private": true,
  "description": "FRONTIER-AUDIT Layer-1 E1.1 third-element closure — graph anomaly detection over the Neo4j entity graph + LLM-driven hypothesis generation. Surfaces fraud topologies that the 81 deterministic patterns do not yet detect. Hypotheses go through a human curation queue before promotion to formal patterns.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/audit-chain": "workspace:*",
    "@vigil/db-neo4j": "workspace:*",
    "@vigil/db-postgres": "workspace:*",
    "@vigil/llm": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/queue": "workspace:*",
    "@vigil/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  }
}
