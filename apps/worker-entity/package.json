{
  "name": "worker-entity",
  "version": "0.1.0",
  "private": true,
  "description": "Entity resolution — LLM-assisted alias dedup + relationship extraction.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
