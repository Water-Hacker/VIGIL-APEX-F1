{
  "name": "audit-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "UDS HTTP sidecar — exposes audit-chain.append() so non-TS workers (Python worker-satellite, Bash maintenance) can write to the canonical audit chain.",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/audit-chain": "workspace:*",
    "@vigil/db-postgres": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/shared": "workspace:*",
    "fastify": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
