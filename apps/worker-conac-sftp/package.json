{
  "name": "worker-conac-sftp",
  "version": "0.1.0",
  "private": true,
  "description": "CONAC SFTP delivery worker — manifest, ACK loop, format-adapter layer (W-25).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/index.js",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/audit-chain": "workspace:*",
    "@vigil/db-postgres": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/queue": "workspace:*",
    "@vigil/security": "workspace:*",
    "@vigil/shared": "workspace:*",
    "kubo-rpc-client": "^4.1.2",
    "ssh2-sftp-client": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/ssh2-sftp-client": "^9.0.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
