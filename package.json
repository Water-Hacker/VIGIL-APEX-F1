{
  "name": "vigil-apex",
  "version": "0.1.0",
  "private": true,
  "description": "Real-Time Public Finance Compliance, Governance Monitoring & Intelligence Platform — République du Cameroun",
  "license": "UNLICENSED",
  "author": {
    "name": "Junior Thuram Nana",
    "email": "satoshinakamotobull@gmail.com",
    "url": "https://vigilapex.cm"
  },
  "engines": {
    "node": ">=22.13.0 <23.0.0",
    "pnpm": ">=9.7.0"
  },
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "turbo run test:integration",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rimraf node_modules \"packages/*/node_modules\" \"apps/*/node_modules\" \"contracts/node_modules\" \".turbo\"",
    "audit:secrets": "gitleaks detect --no-git --redact",
    "audit:deps": "pnpm audit --prod --audit-level=high",
    "audit:licenses": "license-checker --production --summary",
    "verify:ledger": "node packages/audit-chain/dist/scripts/verify-ledger.js",
    "verify:hashchain": "node packages/audit-chain/dist/scripts/verify-hashchain.js",
    "compose:precheck": "node_modules/.pnpm/node_modules/.bin/tsx scripts/check-source-credentials.ts",
    "compose:up": "docker compose -f infra/docker/docker-compose.yaml --env-file infra/docker/.env up -d",
    "compose:down": "docker compose -f infra/docker/docker-compose.yaml down",
    "compose:logs": "docker compose -f infra/docker/docker-compose.yaml logs -f",
    "compose:health": "docker compose -f infra/docker/docker-compose.yaml ps",
    "compose:smoke": "bash scripts/smoke-stack.sh",
    "db:migrate": "pnpm --filter @vigil/db-postgres run migrate",
    "db:seed": "pnpm --filter @vigil/db-postgres run seed",
    "db:reset": "pnpm --filter @vigil/db-postgres run reset",
    "contracts:build": "pnpm --filter contracts run build",
    "contracts:test": "pnpm --filter contracts run test",
    "contracts:deploy:mumbai": "pnpm --filter contracts run deploy:mumbai",
    "contracts:deploy:mainnet": "pnpm --filter contracts run deploy:mainnet",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.11.0",
    "@types/node": "^20.16.5",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^55.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.6",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "turbo": "^2.1.2",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "axios@<1.7.4": ">=1.7.4",
      "ws@<8.17.1": ">=8.17.1"
    },
    "auditConfig": {
      "ignoreCves": []
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
