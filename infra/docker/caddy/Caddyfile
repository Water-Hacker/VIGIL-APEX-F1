# VIGIL APEX Caddyfile — TLS termination + reverse proxy.
# SRD §9.4. ACME via Let's Encrypt (CAA pinned at the registrar).
#
# Rate-limiting is provided by the `mholt/caddy-ratelimit` plugin (compiled
# into the vigil-caddy image — see infra/docker/dockerfiles/Caddy.Dockerfile).
# Per-surface zones, keyed on client IP via {remote_host}:
#   tip_submit       5  req/min  — public POST, anti-spam (THREAT-MODEL §02 floods)
#   tip_browse      30  req/min  — GET /tip, /tip/status?ref=
#   council_vote    20  req/min  — authenticated WebAuthn flow (operator network)
#   findings_api    60  req/min  — operator dashboard normal usage
#   verify_public  120  req/min  — public read; spike-tolerant
#   keycloak_login  10  req/min  — brute-force guard
# Bucket capacity = "max" tokens; refill = max per "window".

{
    email ops@vigilapex.cm
    auto_https on
    servers {
        protocols h1 h2 h3
    }
    order rate_limit before reverse_proxy
}

# ----------------------------------------------------------------------------
# Internal health (used by Docker healthcheck)
# ----------------------------------------------------------------------------
:80 {
    @health path /healthz
    handle @health {
        respond "ok" 200
    }
    redir https://{host}{uri} permanent
}

# ----------------------------------------------------------------------------
# Operator dashboard — authenticated surface
# ----------------------------------------------------------------------------
vigilapex.cm, www.vigilapex.cm {
    encode {
        zstd
        gzip 6
        minimum_length 1024
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Content-Security-Policy "default-src 'self'; img-src 'self' data: blob: https://api.mapbox.com; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.mapbox.com wss://vigilapex.cm; frame-ancestors 'none'"
        -Server
    }

    @council_vote path /api/council/vote*
    rate_limit @council_vote {
        zone council_vote {
            key {remote_host}
            events 20
            window 1m
        }
    }

    @findings_api path /api/findings/* /api/dead-letter/* /api/calibration/*
    rate_limit @findings_api {
        zone findings_api {
            key {remote_host}
            events 60
            window 1m
        }
    }

    handle /api/* {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
    handle {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
}

# ----------------------------------------------------------------------------
# Public verify — open read-only
# ----------------------------------------------------------------------------
verify.vigilapex.cm {
    # Compression — zstd preferred, gzip fallback. min_length 1024 means
    # we don't bother compressing tiny health/JSON responses where the
    # overhead exceeds the savings (D10).
    encode {
        zstd
        gzip 6
        minimum_length 1024
    }
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-ancestors 'none'"
        Cache-Control "public, max-age=300, stale-while-revalidate=60"
        Vary "Accept-Encoding"
        -Server
    }

    # Static asset cache hint — Next.js immutable bundle hashes are safe to
    # cache for a year on the public surface (verify is mostly static).
    @static path *.css *.js *.woff2 *.png *.jpg *.svg
    header @static Cache-Control "public, max-age=31536000, immutable"

    @verify_public path /verify/* /ledger*
    rate_limit @verify_public {
        zone verify_public {
            key {remote_host}
            events 120
            window 1m
        }
    }

    handle /verify/* {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
    handle /ledger* {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
    handle {
        respond "VIGIL APEX verification surface" 200
    }
}

# ----------------------------------------------------------------------------
# Tip portal — public-write, anti-bot, rate-limited
# ----------------------------------------------------------------------------
tip.vigilapex.cm {
    encode {
        zstd
        gzip 6
        minimum_length 1024
    }
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        # CSP allowlist Cloudflare Turnstile only
        Content-Security-Policy "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'"
        Referrer-Policy "no-referrer"
        -Server
    }

    # Submit endpoint: tightest budget — 5/min/IP; abuse → drop to dead-letter.
    @tip_submit path /api/tip/submit
    rate_limit @tip_submit {
        zone tip_submit {
            key {remote_host}
            events 5
            window 1m
        }
    }

    # Browse / status endpoints: looser, but still bounded.
    @tip_browse path /tip /tip/status* /api/tip/status*
    rate_limit @tip_browse {
        zone tip_browse {
            key {remote_host}
            events 30
            window 1m
        }
    }

    handle /tip* {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
    handle /api/tip/* {
        reverse_proxy vigil-dashboard:3000 {
            lb_policy round_robin
            lb_try_duration 5s
            health_uri /api/health
            health_interval 10s
        }
    }
}

# ----------------------------------------------------------------------------
# Keycloak
# ----------------------------------------------------------------------------
kc.vigilapex.cm {
    encode {
        zstd
        gzip 6
        minimum_length 1024
    }

    @keycloak_login path /realms/*/protocol/openid-connect/token /realms/*/protocol/openid-connect/auth
    rate_limit @keycloak_login {
        zone keycloak_login {
            key {remote_host}
            events 10
            window 1m
        }
    }

    reverse_proxy vigil-keycloak:8080 {
        header_up Host {host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
