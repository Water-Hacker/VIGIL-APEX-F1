{
  "title": "VIGIL — Workers",
  "uid": "vigil-workers",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["vigil", "workers"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "worker",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(vigil_worker_inflight, worker)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "description": "Block-D C4 dashboard #2 — per-worker queue lag, throughput, error rates. One row per worker via the $worker template variable. Per architect signoff 2026-05-01.",
  "panels": [
    {
      "type": "stat",
      "title": "Workers up (job=vigil-workers)",
      "targets": [{ "expr": "count(up{job=\"vigil-workers\"} == 1)", "legendFormat": "up" }],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Workers stalled (last-tick > 1h)",
      "targets": [
        {
          "expr": "count(time() - vigil_worker_last_tick_seconds > 3600)",
          "legendFormat": "stalled"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Total inflight (sum)",
      "targets": [{ "expr": "sum(vigil_worker_inflight)" }],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Errors / 5m",
      "targets": [{ "expr": "sum(increase(vigil_errors_total[5m]))" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Inflight per worker — $worker",
      "targets": [
        {
          "expr": "vigil_worker_inflight{worker=~\"$worker\"}",
          "legendFormat": "{{worker}}"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Effective concurrency per worker — $worker",
      "targets": [
        {
          "expr": "vigil_worker_effective_concurrency{worker=~\"$worker\"}",
          "legendFormat": "{{worker}}"
        }
      ],
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Events consumed per worker — $worker",
      "targets": [
        {
          "expr": "rate(vigil_events_consumed_total{worker=~\"$worker\"}[5m])",
          "legendFormat": "{{worker}}"
        }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Events emitted per worker — $worker",
      "targets": [
        {
          "expr": "rate(vigil_events_emitted_total{worker=~\"$worker\"}[5m])",
          "legendFormat": "{{worker}}"
        }
      ],
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Error rate per service — $worker",
      "targets": [
        {
          "expr": "rate(vigil_errors_total{service=~\"$worker\"}[5m])",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Processing duration p99 per worker — $worker",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(vigil_processing_duration_seconds_bucket{worker=~\"$worker\"}[5m]))",
          "legendFormat": "{{worker}}"
        }
      ],
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 }
    }
  ]
}
