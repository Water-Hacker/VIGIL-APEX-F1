{
  "uid": "vigil-council",
  "title": "Council vote latency",
  "description": "Time-to-quorum and per-pillar response cadence (DECISION-008 C5).",
  "tags": ["vigil", "council", "governance"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "Africa/Douala",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Votes by choice (5m)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (choice) (rate(vigil_council_vote_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Votes by pillar",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pillar) (increase(vigil_council_vote_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table"
        }
      }
    }
  ],
  "editable": true
}
