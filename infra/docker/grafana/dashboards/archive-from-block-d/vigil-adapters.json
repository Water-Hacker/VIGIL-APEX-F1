{
  "title": "VIGIL — Adapter health",
  "uid": "vigil-adapters",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "tags": ["vigil", "adapters"],
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "table",
      "title": "Per-source run outcomes (24h)",
      "targets": [
        {
          "expr": "sum by (source, outcome) (increase(vigil_adapter_runs_total[24h]))",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 10 }
    },
    {
      "type": "stat",
      "title": "Sources blocked",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(count by (source) (increase(vigil_adapter_runs_total{outcome=\"blocked\"}[1h])))"
        }
      ],
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 }
    },
    {
      "type": "stat",
      "title": "First-contact failures",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(increase(vigil_adapter_runs_total{outcome=\"first_contact_failed\"}[24h]))" }
      ],
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 5 }
    },
    {
      "type": "timeseries",
      "title": "Rows emitted per source (5m rate)",
      "targets": [
        {
          "expr": "sum by (source) (rate(vigil_adapter_rows_emitted_total[5m]))",
          "legendFormat": "{{source}}"
        }
      ],
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 }
    }
  ]
}
