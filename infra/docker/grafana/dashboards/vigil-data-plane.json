{
  "title": "VIGIL — Data plane",
  "uid": "vigil-data-plane",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["vigil", "data-plane", "infra"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "description": "Block-D C4 dashboard #1 — Postgres + Neo4j + Redis + IPFS health and saturation. Per architect signoff 2026-05-01.",
  "panels": [
    {
      "type": "stat",
      "title": "Postgres up",
      "targets": [{ "expr": "min(pg_up)", "legendFormat": "up" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "PG pool waiting (saturation)",
      "targets": [{ "expr": "max(vigil_db_pool_waiting)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "PG pool idle / total",
      "targets": [
        { "expr": "max(vigil_db_pool_idle)", "legendFormat": "idle" },
        { "expr": "max(vigil_db_pool_total)", "legendFormat": "total" }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "PG transaction duration (p50/p95/p99)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vigil_db_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vigil_db_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(vigil_db_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Neo4j mirror state — failed",
      "targets": [{ "expr": "max(vigil_neo4j_mirror_state_total{state=\"failed\"})" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Neo4j mirror state — pending",
      "targets": [{ "expr": "max(vigil_neo4j_mirror_state_total{state=\"pending\"})" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Neo4j mirror state distribution (synced / pending / failed)",
      "targets": [
        {
          "expr": "sum by (state) (vigil_neo4j_mirror_state_total)",
          "legendFormat": "{{state}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Redis stream PEL length (per stream)",
      "targets": [
        {
          "expr": "max by (stream) (vigil_redis_stream_pel_length)",
          "legendFormat": "{{stream}}"
        }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Redis ack latency p99",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(vigil_redis_ack_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "IPFS — kubo swarm peers",
      "targets": [{ "expr": "max(kubo_swarm_peers_total)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "IPFS pin success rate (last 1h)",
      "targets": [
        {
          "expr": "sum(rate(vigil_ipfs_pins_total{outcome=\"ok\"}[1h])) / clamp_min(sum(rate(vigil_ipfs_pins_total[1h])), 0.001)",
          "legendFormat": "ok-fraction"
        }
      ],
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 }
    }
  ]
}
