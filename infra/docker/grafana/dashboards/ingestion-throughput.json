{
  "uid": "vigil-ingestion",
  "title": "Adapter ingestion throughput",
  "description": "Phase 1 source-adapter health: rows/min by source, failure rate, rate-limit headroom.",
  "tags": [
    "vigil",
    "ingestion"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "Africa/Douala",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rows emitted (5m rate)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source_id) (rate(vigil_adapter_rows_emitted_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Adapter runs (5m rate)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(vigil_adapter_runs_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors last 1h",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(vigil_errors_total[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active adapters",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vigil-prom"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(group by (source_id) (vigil_adapter_runs_total))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "editable": true
}
