{
  "name": "contracts",
  "version": "0.1.0",
  "private": true,
  "description": "VIGIL APEX smart contracts — Polygon mainnet (SRD §22).",
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "gas": "REPORT_GAS=true hardhat test",
    "deploy:mumbai": "hardhat run scripts/deploy.ts --network mumbai",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network polygon",
    "verify:mumbai": "hardhat verify --network mumbai",
    "verify:mainnet": "hardhat verify --network polygon",
    "lint": "solhint 'contracts/**/*.sol'",
    "typecheck": "tsc --noEmit",
    "clean": "hardhat clean && rimraf cache artifacts typechain-types"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.10",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.19",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.16.5",
    "chai": "^4.5.0",
    "ethers": "^6.13.2",
    "hardhat": "^2.22.10",
    "hardhat-gas-reporter": "^2.2.1",
    "rimraf": "^6.0.1",
    "solhint": "^5.0.3",
    "solidity-coverage": "^0.8.13",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.2"
  }
}
