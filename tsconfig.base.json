{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "composite": false,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "removeComments": false,
    "preserveConstEnums": true,

    "baseUrl": ".",
    "paths": {
      "@vigil/shared": ["packages/shared/src"],
      "@vigil/shared/*": ["packages/shared/src/*"],
      "@vigil/db-postgres": ["packages/db-postgres/src"],
      "@vigil/db-postgres/*": ["packages/db-postgres/src/*"],
      "@vigil/db-neo4j": ["packages/db-neo4j/src"],
      "@vigil/db-neo4j/*": ["packages/db-neo4j/src/*"],
      "@vigil/queue": ["packages/queue/src"],
      "@vigil/queue/*": ["packages/queue/src/*"],
      "@vigil/observability": ["packages/observability/src"],
      "@vigil/observability/*": ["packages/observability/src/*"],
      "@vigil/security": ["packages/security/src"],
      "@vigil/security/*": ["packages/security/src/*"],
      "@vigil/llm": ["packages/llm/src"],
      "@vigil/llm/*": ["packages/llm/src/*"],
      "@vigil/audit-chain": ["packages/audit-chain/src"],
      "@vigil/audit-chain/*": ["packages/audit-chain/src/*"],
      "@vigil/governance": ["packages/governance/src"],
      "@vigil/governance/*": ["packages/governance/src/*"],
      "@vigil/dossier": ["packages/dossier/src"],
      "@vigil/dossier/*": ["packages/dossier/src/*"],
      "@vigil/patterns": ["packages/patterns/src"],
      "@vigil/patterns/*": ["packages/patterns/src/*"],
      "@vigil/adapters": ["packages/adapters/src"],
      "@vigil/adapters/*": ["packages/adapters/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", "out", "coverage", ".turbo"]
}
