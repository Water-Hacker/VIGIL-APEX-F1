{
  "name": "@vigil/security",
  "version": "0.1.0",
  "private": true,
  "description": "Vault client, mTLS auto-renew, libsodium ops, FIDO2/WebAuthn verifier.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@simplewebauthn/server": "^11.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "@vigil/observability": "workspace:*",
    "@vigil/shared": "workspace:*",
    "libsodium-wrappers-sumo": "^0.7.13",
    "node-vault": "^0.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
