{
  "name": "@vigil/llm",
  "version": "0.1.0",
  "private": true,
  "description": "LLM tier router (Anthropic + Bedrock failover + local sovereign), prompt registry, anti-hallucination, cost tracker.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist", "prompts"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:hallucinations": "vitest run __tests__/hallucinations.test.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@anthropic-ai/bedrock-sdk": "^0.12.6",
    "@vigil/observability": "workspace:*",
    "@vigil/security": "workspace:*",
    "@vigil/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
