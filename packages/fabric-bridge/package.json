{
  "name": "@vigil/fabric-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Hyperledger Fabric SDK wrapper used by worker-fabric-bridge and the cross-witness audit verifier.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hyperledger/fabric-gateway": "^1.6.0",
    "@vigil/observability": "workspace:*",
    "@vigil/security": "workspace:*",
    "@vigil/shared": "workspace:*",
    "@grpc/grpc-js": "^1.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
