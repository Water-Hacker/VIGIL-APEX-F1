{
  "name": "@vigil/db-neo4j",
  "version": "0.1.0",
  "private": true,
  "description": "Neo4j Bolt client + custom GDS (PageRank, Louvain, NodeSimilarity).",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/observability": "workspace:*",
    "@vigil/shared": "workspace:*",
    "neo4j-driver": "^5.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
