{
  "name": "@vigil/audit-log",
  "version": "0.1.0",
  "private": true,
  "description": "TAL-PA SDK \u2014 Total Action Logging with Public Anchoring (DECISION-012). Workers + the dashboard import emit() to record every user action; the SDK chains per-actor, computes the record hash, writes both to audit.actions (global chain) and audit.user_action_event (rich record), and marks high-significance events for immediate Polygon anchoring.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=2000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vigil/audit-chain": "workspace:*",
    "@vigil/db-postgres": "workspace:*",
    "@vigil/observability": "workspace:*",
    "@vigil/shared": "workspace:*",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
